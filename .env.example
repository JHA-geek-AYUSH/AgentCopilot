# ============================================================
# AgentOS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# -----------------------------------------------------------
# Clerk Authentication (REQUIRED)
# Get these from https://dashboard.clerk.com → your app → API Keys
# -----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------
# Supabase (REQUIRED)
# Get these from https://supabase.com/dashboard → your project → Settings → API
# -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — only needed for admin/server-side operations
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------
# GLM / AI Model API
# -----------------------------------------------------------
GLM_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
GLM_API_KEY=

# Legacy aliases (kept for backward compat — prefer GLM_* above)
GOOGLE_API_URL=
GOOGLE_API_KEY=

# -----------------------------------------------------------
# App Config
# -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------
# GitHub Integration (optional)
# -----------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------
# Twitter / X Integration (optional)
# -----------------------------------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# -----------------------------------------------------------
# Email / SMTP (optional)
# -----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=osap@agent.ai

# -----------------------------------------------------------
# Composio — Advanced Tool Integrations (optional)
# Get your key from https://app.composio.dev
# -----------------------------------------------------------
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_PROJECT_NAME=osap-main
# COMPOSIO_SESSION_TTL_SECONDS=3600
# COMPOSIO_MAX_SESSIONS=10

# -----------------------------------------------------------
# HydraDB — Memory System (optional)
# -----------------------------------------------------------
NEXT_PUBLIC_HYDRA_DB_API_KEY=
NEXT_PUBLIC_HYDRA_DB_TENANT_ID=
NEXT_PUBLIC_HYDRA_DB_SUB_TENANT_ID=osap

# -----------------------------------------------------------
# Firecrawl — Web Knowledge Ingestion (optional)
# -----------------------------------------------------------
NEXT_PUBLIC_FIRECRAWL_API_KEY=

# -----------------------------------------------------------
# NANDA publishing — publish /agent agents to the NANDA directory
# See docs/prd.md
# -----------------------------------------------------------
NANDA_ENABLED=true
NANDA_RUNTIME_ENABLED=true
NANDA_PUBLIC_BASE_URL=https://agentos.app
NANDA_REGISTRY_BASE_URL=https://agentos.app/api/nanda   # what the Index points to
NANDA_INDEX_API_URL=https://api.nandaindex.org
NANDA_ORG_DOMAIN=agentos.app
NANDA_ORG_ID=                                           # filled after onboarding script
NANDA_PROVIDER_NAME=Paramarsh Labs
# Set true to block publishing until the org is onboarded in the NANDA Index.
NANDA_REQUIRE_ORG=false

# Optional: mirror into an external nanda-registry instead of / in addition to self-registry
NANDA_EXTERNAL_REGISTRY_URL=
NANDA_EXTERNAL_REGISTRY_JWT=

# Optional Phase 2: signed AgentFacts (Ed25519, base64)
NANDA_SIGNING_PRIVATE_KEY=
